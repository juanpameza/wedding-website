# ─── RSVP (Airtable) ───────────────────────────────────────────────────────
# Create a base with two tables (Households, Guests) per the design doc, then:
# Airtable → Developer hub → Personal access token, scoped to data.records:read
# + data.records:write on THIS base only.
AIRTABLE_TOKEN=pat_xxx
AIRTABLE_BASE_ID=app_xxx

# Guests are listed in this view's order, so party members show up on the form in
# the same order as your Airtable rows. Defaults to "Grid view".
AIRTABLE_GUESTS_VIEW=Grid view

# ─── RSVP submit notifications (optional) ───────────────────────────────────
# If unset, submits are logged server-side instead of emailed.
RESEND_API_KEY=
RSVP_NOTIFY_EMAIL=
RSVP_NOTIFY_FROM=rsvp@resend.dev
